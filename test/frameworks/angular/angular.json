{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "pnpm",
    "cache": {
      "enabled": false
    },
    "analytics": false
  },
  "projects": {
    "favicon-env-angular": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [{ "glob": "**/*", "input": "public" }],
            "server": "src/main.server.ts",
            "outputMode": "server",
            "security": { "allowedHosts": ["127.0.0.1", "localhost"] },
            "ssr": { "entry": "src/server.ts" }
          },
          "configurations": {
            "prod": {
              "define": { "APP_ENV": "'prod'" },
              "fileReplacements": [
                {
                  "replace": "src/app/favicon-env-loader.ts",
                  "with": "src/app/favicon-env-loader.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "staging": {
              "define": { "APP_ENV": "'staging'" },
              "outputHashing": "all"
            },
            "dev": {
              "define": { "APP_ENV": "'dev'" },
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "prod"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "dev": { "buildTarget": "favicon-env-angular:build:dev" }
          },
          "defaultConfiguration": "dev"
        }
      }
    }
  }
}
